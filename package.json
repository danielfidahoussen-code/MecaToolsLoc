{
  "name": "lvtools",
  "version": "1.0.0",
  "description": "PrestoLocation - Location et vente d'outillage",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "stripe": "^22.2.0"
  }
}
